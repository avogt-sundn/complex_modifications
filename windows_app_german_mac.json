{
    "title": "Windows App: vom deutschen Mac-Keyboard",
    "rules": [
        {
            "description": "Windows App: (deutsch Mac) → (deutsch Windows)",
            "manipulators": [
                // [ = Option+5 (Mac deutsch) → AltGr+8 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "5",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "8",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // ] = Option+6 (Mac deutsch) → AltGr+9 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "6",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "9",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // { = Option+8 (Mac deutsch) → AltGr+7 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "8",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "7",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // } = Option+9 (Mac deutsch) → AltGr+0 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "9",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "0",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // | = Option+7 (Mac deutsch) -> AltGr+< (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "7",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "non_us_backslash",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // \ = Option+Shift+7 (Mac deutsch) -> AltGr+ß (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "7",
                        "modifiers": {
                            "mandatory": [
                                "option",
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "hyphen",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // ~ = Option+N (Mac deutsch) -> AltGr+] dead key + space resolves to literal ~ on German Windows
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "n",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "close_bracket",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // @ = Option+L (Mac deutsch) -> AltGr+Q (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "l",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "q",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // < = key reported by EventViewer (Mac) -> < (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "grave_accent_and_tilde"
                    },
                    "to": [
                        {
                            "key_code": "grave_accent_and_tilde"
                        }
                    ]
                },
                // > = Shift+key reported by EventViewer (Mac) -> > (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "grave_accent_and_tilde",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "grave_accent_and_tilde",
                            "modifiers": [
                                "shift"
                            ]
                        }
                    ]
                },
                // ^ = German Mac key -> dead key + space resolves to literal ^ on German Windows
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "non_us_backslash"
                    },
                    "to": [
                        {
                            "key_code": "grave_accent_and_tilde"
                        },
                        {
                            "key_code": "spacebar"
                        }
                    ]
                },
                // ° = Shift + German Mac key for ^/° -> Shift + German Windows ^/° key
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "non_us_backslash",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "grave_accent_and_tilde",
                            "modifiers": [
                                "shift"
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}