{
    "title": "ANSI Gleich",
    "rules": [
        {
            "description": "ANSI Gleich",
            "manipulators": [
                // =
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "equal_sign"
                    },
                    "to": [
                        {
                            "key_code": "0",
                            "modifiers": [
                                "left_shift"
                            ]
                        }
                    ]
                },
                // +
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "equal_sign",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "close_bracket"
                        }
                    ]
                }
            ]
        }
    ]
}