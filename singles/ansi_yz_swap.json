{
    "title": "ANSI Y/Z Swap",
    "rules": [
        {
            "description": "ANSI Y/Z Swap",
            "manipulators": [
                // y → z
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "y",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "z"
                        }
                    ]
                },
                // z → y
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "z",
                        "modifiers": {
                            "optional": [
                                "any"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "y"
                        }
                    ]
                }
            ]
        }
    ]
}