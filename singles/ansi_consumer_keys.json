{
    "title": "ANSI function keys",
    "rules": [
        {
            "description": "Sondertasten auf den F-keys mit Fn aktivieren",
            "manipulators": [
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "f2"
                    },
                    "to": [
                        {
                            "consumer_key_code": "display_brightness_increment"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "f1"
                    },
                    "to": [
                        {
                            "consumer_key_code": "display_brightness_decrement"
                        }
                    ]
                }
            ]
        }
    ]
}