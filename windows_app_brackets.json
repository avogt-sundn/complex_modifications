{
    "title": "Windows App: Eckige und geschweifte Klammern (Deutsch)",
    "rules": [
        {
            "description": "Windows App: Klammern für deutsches Windows-Layout (AltGr statt Option)",
            "manipulators": [
                // [ via AltGr+8 (deutsch Windows)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "open_bracket"
                    },
                    "to": [
                        {
                            "key_code": "8",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // ] via AltGr+9 (deutsch Windows)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "close_bracket"
                    },
                    "to": [
                        {
                            "key_code": "9",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // { via AltGr+7 (deutsch Windows)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "open_bracket",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "7",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // } via AltGr+0 (deutsch Windows)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": false
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "close_bracket",
                        "modifiers": {
                            "mandatory": [
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "0",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}