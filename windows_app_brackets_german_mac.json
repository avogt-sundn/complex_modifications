{
    "title": "Windows App: Eckige und geschweifte Klammern vom deutschen Mac-Keyboard",
    "rules": [
        {
            "description": "Windows App: Option+5/6/8/9 (deutsch Mac) → AltGr+8/9/7/0 (deutsch Windows)",
            "manipulators": [
                // [ = Option+5 (Mac deutsch) → AltGr+8 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "5",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "8",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // ] = Option+6 (Mac deutsch) → AltGr+9 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "6",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "9",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // { = Option+8 (Mac deutsch) → AltGr+7 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "8",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "7",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // } = Option+9 (Mac deutsch) → AltGr+0 (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "9",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "0",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // | = Option+7 (Mac deutsch) -> AltGr+< (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "7",
                        "modifiers": {
                            "mandatory": [
                                "option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "non_us_backslash",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                },
                // \ = Option+Shift+7 (Mac deutsch) -> AltGr+ß (Windows deutsch)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [
                                "^com\\.microsoft\\.rdc\\.macos$"
                            ]
                        },
                        {
                            "type": "device_if",
                            "identifiers": [
                                {
                                    "is_built_in_keyboard": true
                                }
                            ]
                        }
                    ],
                    "from": {
                        "key_code": "7",
                        "modifiers": {
                            "mandatory": [
                                "option",
                                "shift"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "hyphen",
                            "modifiers": [
                                "right_option"
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}