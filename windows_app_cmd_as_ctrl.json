                        "key_code": "v",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "any" ] }
                    },
                    "to": [ { "key_code": "v", "modifiers": [ "left_control" ] } ]
                },

                // X: Ausschneiden
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "x",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "any" ] }
                    },
                    "to": [ { "key_code": "x", "modifiers": [ "left_control" ] } ]
                },

                // Z: Rückgängig; CMD+Shift+Z: Wiederholen
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "y",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "any" ] }
