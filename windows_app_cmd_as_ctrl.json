                // D: Lesezeichen / Zeile duplizieren
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "d",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "any" ] }
                    },
                    "to": [ { "key_code": "d", "modifiers": [ "left_control" ] } ]
                },

                // B+Option: CTRL+ALT+B
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "b",
                        "modifiers": { "mandatory": [ "command", "option" ] }
                    },
                    "to": [ { "key_code": "b", "modifiers": [ "left_control", "left_alt" ] } ]
                },

                // B: Fett
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "b",
