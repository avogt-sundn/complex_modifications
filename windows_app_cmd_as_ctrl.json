{
    "title": "Windows App: CMD als CTRL",
    "rules": [
        {
            "description": "Windows App: Umlaute und CTRL-Shortcuts via CMD (alle Tastaturen)",
            "manipulators": [

                // ============================================================
                // Zeichen — stehen vor den CTRL-Shortcuts damit sie Vorrang haben
                // ============================================================

                // left/right CMD → CTRL: Windows never sees the Windows key (prevents Start menu)
                // Must be first so subsequent rules see CTRL, not CMD
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": { "key_code": "left_command" },
                    "to": [ { "key_code": "left_control" } ]
                },
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": { "key_code": "right_command" },
                    "to": [ { "key_code": "right_control" } ]
                },

                // CTRL+TAB: swallow — CMD was remapped to CTRL above, so this catches CMD+TAB
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "tab",
                        "modifiers": { "mandatory": [ "control" ], "optional": [ "any" ] }
                    },
                    "to": []
                },

                // @: Shift+2 → AltGr+Q (Windows German Layout)
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "2",
                        "modifiers": { "mandatory": [ "shift" ] }
                    },
                    "to": [ { "key_code": "q", "modifiers": [ "right_option" ] } ]
                },

                // ============================================================
                // Umlaute — stehen vor den CTRL-Shortcuts damit sie Vorrang haben
                // ============================================================

                // ß: CMD+/
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "slash",
                        "modifiers": { "mandatory": [ "command" ] }
                    },
                    "to": [ { "key_code": "hyphen" } ]
                },

                // ü / Ü: CMD+[ / CMD+Shift+[
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "open_bracket",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "shift" ] }
                    },
                    "to": [ { "key_code": "open_bracket" } ]
                },

                // ö / Ö: CMD+; / CMD+Shift+;
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "semicolon",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "shift" ] }
                    },
                    "to": [ { "key_code": "semicolon" } ]
                },

                // ä / Ä: CMD+' / CMD+Shift+'
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "quote",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "shift" ] }
                    },
                    "to": [ { "key_code": "quote" } ]
                },

                // ============================================================
                // CMD → CTRL Shortcuts
                // optional: [any] gibt alle weiteren Modifier (Shift, Option …)
                // unverändert an Windows weiter, z.B. CMD+Shift+Z → CTRL+Shift+Z
                // ============================================================

                // A: Alles auswählen
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
                        }
                    ],
                    "from": {
                        "key_code": "a",
                        "modifiers": { "mandatory": [ "command" ], "optional": [ "any" ] }
                    },
                    "to": [ { "key_code": "a", "modifiers": [ "left_control" ] } ]
                },

                // C: Kopieren
                {
                    "type": "basic",
                    "conditions": [
                        {
                            "type": "frontmost_application_if",
                            "bundle_identifiers": [ "^com\\.microsoft\\.rdc\\.macos$" ]
